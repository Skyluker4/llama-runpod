root = true

[*]
end_of_line = lf
insert_final_newline = true
indent_style = tab

[LICENSE]
indent_style = unset
indent_size = unset

[*.conf]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[Dockerfile]
indent_style = space
indent_size = 4

[*.md]
indent_style = space
indent_size = unset
